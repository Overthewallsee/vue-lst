{
  "name": "vue-login",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:test": "vite build --mode test",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@stomp/stompjs": "^7.3.0",
    "axios": "^1.18.1",
    "crypto-js": "^4.2.0",
    "element-plus": "^2.14.2",
    "vconsole": "^3.15.1",
    "vue": "^3.5.21",
    "vue-native-websocket": "^2.0.15",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^24.6.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "electron": "^38.2.2",
    "electron-builder": "^26.0.12",
    "electron-is-dev": "^3.0.1",
    "postcss": "^8.5.6",
    "sass": "^1.101.0",
    "vite": "npm:rolldown-vite@7.1.12"
  },
  "build": {
    "appId": "com.vue-login.desktop",
    "productName": "Vue Login Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "electronBuilder": {
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    }
  }
}
